{
  "name": "obsidian-paperize",
  "version": "0.3.0",
  "description": "Clean Markdown to PDF for Obsidian",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc --noEmit && node esbuild.config.mjs --production",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "check:pure": "sh -c \"! grep -rl 'from .obsidian.' src/core src/vendor --exclude-dir=obsidian 2>/dev/null\"",
    "gate": "npm run typecheck && npm test && npm run check:pure && npm run build",
    "deploy": "npm run build && cp main.js manifest.json styles.css \"${OBSIDIAN_PLUGIN_DIR:?set OBSIDIAN_PLUGIN_DIR}\"/",
    "version-bump": "node scripts/version-bump.mjs",
    "release": "node scripts/release.mjs"
  },
  "keywords": [
    "obsidian",
    "pdf",
    "markdown",
    "export"
  ],
  "author": "Johannes Kaindl",
  "license": "AGPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "git+https://codeberg.org/jkaindl/obsidian-paperize.git"
  },
  "homepage": "https://codeberg.org/jkaindl/obsidian-paperize",
  "bugs": {
    "url": "https://codeberg.org/jkaindl/obsidian-paperize/issues"
  },
  "devDependencies": {
    "@types/node": "^20",
    "esbuild": "^0.20.0",
    "happy-dom": "^20.10.6",
    "obsidian": "latest",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
